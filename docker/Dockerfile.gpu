FROM nvidia/cuda:12.4.1-cudnn-devel-ubuntu22.04

ENV DEBIAN_FRONTEND=noninteractive \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1 \
    HF_HOME=/workspace/.cache/huggingface

# ── System packages ────────────────────────────────────────────────────────────
RUN apt-get update && apt-get install -y \
    python3.11 \
    python3.11-dev \
    python3-pip \
    git \
    wget \
    curl \
    poppler-utils \
    libgl1 \
    libglib2.0-0 \
    build-essential \
    && ln -sf /usr/bin/python3.11 /usr/bin/python \
    && ln -sf /usr/bin/python3.11 /usr/bin/python3 \
    && rm -rf /var/lib/apt/lists/*

# ── Upgrade pip ────────────────────────────────────────────────────────────────
RUN python -m pip install --upgrade pip packaging setuptools wheel ninja

# ══════════════════════════════════════════════════════════════════════════════
# torch, torchvision
# ══════════════════════════════════════════════════════════════════════════════
RUN pip install \
    torch==2.6.0 \
    torchvision==0.21.0 \
    --index-url https://download.pytorch.org/whl/cu124

# ══════════════════════════════════════════════════════════════════════════════
# flash-attention
# ══════════════════════════════════════════════════════════════════════════════
RUN pip install psutil ninja
RUN pip install flash_attn==2.7.4.post1 \
    --no-build-isolation

# ══════════════════════════════════════════════════════════════════════════════
# torch-related dependencies
# ══════════════════════════════════════════════════════════════════════════════
RUN DS_BUILD_OPS=0 pip install \
    torch==2.6.0 \
    triton==3.2.0 \
    vllm==0.8.5 \
    deepspeed==0.16.3 \
    cuml-cu12 \
    torchcodec==0.2.0 \
    --extra-index-url https://download.pytorch.org/whl/cu124 \
    --extra-index-url https://pypi.nvidia.com

# ══════════════════════════════════════════════════════════════════════════════
# axolotl
# ══════════════════════════════════════════════════════════════════════════════
RUN pip install --no-build-isolation axolotl

# ══════════════════════════════════════════════════════════════════════════════
# other dependencies
# ══════════════════════════════════════════════════════════════════════════════
WORKDIR /workspace
COPY pyproject.toml .
RUN pip install -e ".[dev]"

CMD ["/bin/bash"]